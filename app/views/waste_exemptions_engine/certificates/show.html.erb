<%
  # When this template is used by a controller, the @presenter variable is exposed.
  # But when it is rendered from (eg) the RegistrationActivatedEmailService,
  # the instance variable is not available, only the local one.
  @presenter ||= presenter
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%=t ".title" %></title>
    <%= yield :stylesheets %>
    <meta charset="utf-8" >
    <%= stylesheet_link_tag "certificates", media: "all" %>
  </head>

  <body>
    <%= link_to t('.view_as_pdf'), pdf_certificate_path(@presenter.reference, token: params[:token]), class: "govuk-!-display-none-print govuk-button", target: "_blank" %>
    <div id="wrapper">
      <div class="govuk-width-container">
        <main id="content" role="main" class="group">
          <div class="grid-wrapper">
            <div class="grid-2-3">
              <h1 class="govuk-heading-l"><%=t ".confirmation.heading", registration_number: @presenter.reference %></h1>
              <p class="govuk-body">
                <%=t ".confirmation.paragraph1" %>
              </p>

              <p class="govuk-body">
                <strong><%=t ".confirmation.warning" %></strong>
              </p>

              <p class="govuk-body">
                <%=t ".confirmation.paragraph2", company_registration_number: @presenter.reference %>
                <br \>
                <%= link_to "https://environment.data.gov.uk/public-register/view/search-waste-exemptions", "https://environment.data.gov.uk/public-register/view/search-waste-exemptions" %>
              </p>

              <h1 class="govuk-heading-l"><%=t ".business_responsibilities.heading" %></h1>
              <div class="govuk-body">
                <%=t ".business_responsibilities.first_paragraph.description" %>
                <ul class="govuk-list govuk-list--bullet govuk-!-margin-left-2">
                  <li><%=t ".business_responsibilities.first_paragraph.list_items.first" %></li>
                  <li><%=t ".business_responsibilities.first_paragraph.list_items.second" %></li>
                  <li><%=t ".business_responsibilities.first_paragraph.list_items.third" %></li>
                </ul>
              </div>

              <div class="govuk-body">
                <%=t ".business_responsibilities.second_paragraph.description" %>
                <ul class="govuk-list govuk-list--bullet govuk-!-margin-left-2">
                  <li><%=t ".business_responsibilities.second_paragraph.list_items.first" %></li>
                  <li><%=t ".business_responsibilities.second_paragraph.list_items.second" %></li>
                  <li><%=t ".business_responsibilities.second_paragraph.list_items.third" %></li>
                </ul>
              </div>

              <p class="govuk-body">
                <%=t ".business_responsibilities.paragraph3" %>
              </p>

              <h1 class="govuk-heading-l"><%=t ".registration_details.heading" %></h1>

              <h2 class="govuk-heading-m"><%=t ".registration_details.registration_details.heading" %></h2>
              <div class="table-wrapper">
                <table class="govuk-table">
                  <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.registration_details.reference_number" %></th>
                      <td class="govuk-table__cell"><%= @presenter.reference %></td>
                    </tr>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.registration_details.date_registered" %></th>
                      <td class="govuk-table__cell"><%= @presenter.submitted_at.to_formatted_s(:day_month_year) %></td>
                    </tr>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.registration_details.expiry_date" %></th>
                      <td class="govuk-table__cell"><%= @presenter.expiry_date %></td>
                    </tr>
                  </tbody>
                </table>
              </div>


              <h2 class="govuk-!-margin-top-9 govuk-heading-m"><%=t ".registration_details.business_details.heading" %></h2>
              <div class="table-wrapper">
                <table class="govuk-table">
                  <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.business_details.business_type" %></th>
                      <td class="govuk-table__cell"> <%= @presenter.human_business_type %> </td>
                    </tr>
                    <% if @presenter.partnership? %>
                      <tr class="govuk-table__row">
                        <th class="govuk-table__header" scope="row">
                          <%=t ".registration_details.business_details.partners" %>
                        </th>
                        <td class="govuk-table__cell"> <%= @presenter.partners_names %> </td>
                      </tr>
                    <% else %>
                      <tr class="govuk-table__row">
                        <th class="govuk-table__header" scope="row"><%=t ".registration_details.business_details.responsible_person" %></th>
                        <td class="govuk-table__cell"> <%= @presenter.operator_name %> </td>
                      </tr>
                    <% end %>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.business_details.responsible_person_address" %></th>
                      <td class="govuk-table__cell">
                        <% displayable_address(@presenter.operator_address).each do |line| %>
                          <%= line %><br>
                        <% end %>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <h2 class="govuk-!-margin-top-9 govuk-heading-m"><%=t ".registration_details.waste_operations_contact.heading" %></h2>
              <div class="table-wrapper">
                <table class="govuk-table">
                  <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.waste_operations_contact.name" %></th>
                      <td class="govuk-table__cell"> <%= @presenter.contact_name %> </td>
                    </tr>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.waste_operations_contact.position" %></th>
                      <td class="govuk-table__cell"> <%= @presenter.contact_position %> </td>
                    </tr>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.waste_operations_contact.telephone_n" %></th>
                      <td class="govuk-table__cell"> <%= @presenter.contact_phone %> </td>
                    </tr>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.waste_operations_contact.email" %></th>
                      <td class="govuk-table__cell"> <%= @presenter.contact_email %> </td>
                    </tr>
                    <tr class="govuk-table__row">
                      <th class="govuk-table__header" scope="row"><%=t ".registration_details.waste_operations_contact.address" %></th>
                      <td class="govuk-table__cell">
                        <% displayable_address(@presenter.contact_address).each do |line| %>
                          <%= line %><br>
                        <% end %>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <h2 class="govuk-!-margin-top-9 govuk-heading-m"><%=t ".registration_details.exemptions.active_heading" %></h2>
              <ul class="govuk-list govuk-list--bullet govuk-!-margin-left-2">
                <% @presenter.unique_active_registration_exemptions.each do |registration_exemption| %>
                  <li><%= "#{registration_exemption.exemption.code}: #{registration_exemption.exemption.summary}" %></li>
                <% end %>
              </ul>

              <h2 class="govuk-!-margin-top-9 govuk-heading-m"><%=t ".registration_details.waste_operations_details.heading" %></h2>
                <% @presenter.site_addresses.each_with_index do |address, index| %>
                  <div class="table-wrapper">
                    <table class="govuk-table">
                      <tbody class="govuk-table__body">
                      <% if address.located_by_grid_reference? %>
                        <tr class="govuk-table__row">
                          <th class="govuk-table__header" scope="row"><%= "#{index + 1}." %> <%=t ".registration_details.waste_operations_details.grid_reference" %></th>
                          <td class="govuk-table__cell"><%= address.grid_reference %></td>
                        </tr>
                      <% else %>
                        <tr class="govuk-table__row">
                          <th class="govuk-table__header" scope="row"><%= "#{index + 1}." %> <%=t ".registration_details.waste_operations_details.location" %></th>
                          <td class="govuk-table__cell">
                            <% displayable_address(address).each do |line| %>
                              <%= line %><br>
                            <% end %>
                          </td>
                        </tr>
                      <% end %>
                      <% if address.description.present? %>
                        <tr class="govuk-table__row">
                          <th class="govuk-table__header" scope="row"><%=t ".registration_details.waste_operations_details.site_details" %></th>
                          <td class="govuk-table__cell"><%= address.description %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% end %>

              <% deregistered_by_site = @presenter.site_addresses.filter_map { |a| exs = @presenter.deregistered_exemptions_for_site(a).to_a; [a, exs] if exs.any? } %>
              <% if deregistered_by_site.any? %>
                <h2 class="govuk-!-margin-top-9 govuk-heading-m"><%=t ".registration_details.deregistered_exemptions.heading" %></h2>
                <% deregistered_by_site.each do |address, deregistered_exemptions| %>
                  <p class="govuk-body govuk-!-font-weight-bold">
                    <%=t ".registration_details.deregistered_exemptions.site_location" %>: <%= address.located_by_grid_reference? ? address.grid_reference : displayable_address(address).join(", ") %>
                  </p>
                  <ul class="govuk-list govuk-list--bullet govuk-!-margin-left-2">
                    <% deregistered_exemptions.each do |registration_exemption| %>
                      <li>
                        <%= "#{registration_exemption.exemption.code}: #{registration_exemption.exemption.summary}" %>
                        <br><%= @presenter.ceased_or_revoked_on(registration_exemption) %>
                      </li>
                    <% end %>
                  </ul>
                <% end %>
              <% end %>
            </div>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
