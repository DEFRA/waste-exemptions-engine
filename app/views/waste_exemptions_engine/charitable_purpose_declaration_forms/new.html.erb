<%= render("waste_exemptions_engine/shared/back", token: @charitable_purpose_declaration_form.token) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_for(@charitable_purpose_declaration_form) do |f| %>
      <%= render partial: "waste_exemptions_engine/shared/error_summary", locals: { f: f } %>

      <h1 class="govuk-heading-l"><%= t(".heading") %></h1>

      <%= f.govuk_check_boxes_fieldset :charitable_purpose_declaration,
          multiple: false,
          legend: { text: t(".heading"), hidden: true } do %>

        <%= f.govuk_check_box :charitable_purpose_declaration,
          1,
          0,
          multiple: false,
          link_errors: true,
          label: { text: t(".confirmation_text") } %>
      <% end %>

      <%= f.govuk_submit t(".next_button") %>
    <% end %>
  </div>
</div>
